# Copy this file to playwright/.env.test and fill in real test account credentials.
# playwright/.env.test is gitignored — never commit real credentials.
#
# These accounts must exist in your Supabase project:
#   - Founder account: onboarding complete, subscription active
#   - Creative account: onboarding complete, review approved, subscription active

TEST_USER_EMAIL=founder@yourdomain.com
TEST_USER_PASSWORD=YourTestPassword123!

TEST_FOUNDER_EMAIL=founder@yourdomain.com
TEST_FOUNDER_PASSWORD=YourTestPassword123!

TEST_CREATIVE_EMAIL=creative@yourdomain.com
TEST_CREATIVE_PASSWORD=YourTestPassword123!

# For local dev: http://localhost:3000
# For staging:   https://your-preview-url.vercel.app
BASE_URL=http://localhost:3000
